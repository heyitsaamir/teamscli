{
  "name": "teams",
  "version": "1.0.0",
  "description": "CLI for scaffolding Teams applications",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "teams": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:generate": "tsx scripts/generate-command-docs.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "files": [
    "dist",
    "templates",
    "configs",
    "statics"
  ],
  "keywords": [
    "teams",
    "cli",
    "scaffolding"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@azure/msal-node-extensions",
      "@azure/msal-node-runtime",
      "esbuild",
      "keytar"
    ],
    "overrides": {
      "vite": ">=7.3.2",
      "esbuild": ">=0.25.0"
    }
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.4",
    "@azure/msal-node-extensions": "^5.0.4",
    "@inquirer/prompts": "^7.2.1",
    "adm-zip": "^0.5.16",
    "change-case": "^5.4.4",
    "commander": "^12.1.0",
    "env-paths": "^4.0.0",
    "handlebars": "^4.7.9",
    "nanospinner": "^1.2.2",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.0",
    "vitest": "^4.1.4"
  }
}
